# ─── Agent OS — Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in the values you want to use.
# The app ships with a built-in OpenRouter key and works out of the box.

# ── Database (required for server) ───────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/agent_os

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8080          # API server port
API_PORT=8080      # Port the frontend dev proxy points at

# ── Frontend ─────────────────────────────────────────────────────────────────
# PORT=3000        # Vite dev/preview server port
BASE_PATH=/        # URL base path (Netlify sets this automatically)

# ── AI Provider ──────────────────────────────────────────────────────────────
# Leave blank to use the built-in OpenRouter key (default).
# Set AI_PROVIDER to force a specific backend:
#   openrouter | openai | groq | google | replit | ollama

# AI_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-v1-...       # Override built-in key
# AI_MODEL=meta-llama/llama-3.3-70b-instruct   # Any model slug on openrouter.ai

# AI_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# AI_MODEL=llama-3.3-70b-versatile

# AI_PROVIDER=google
# GOOGLE_API_KEY=AIza...
# AI_MODEL=gemini-2.0-flash

# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# AI_MODEL=gpt-4o-mini

# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# AI_MODEL=llama3.2

# ── Replit (auto-populated on Replit) ────────────────────────────────────────
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://...
# AI_INTEGRATIONS_OPENAI_API_KEY=...
